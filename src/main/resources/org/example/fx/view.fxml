<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.web.*?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.fx.PropertyController">
    <children>
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 10;" text="Student Property Finder">
         <font>
            <Font name="SansSerif Bold" size="13.0" />
         </font></Label>
        <Label style="-fx-padding: 0 0 10 10;" text="Edmonton Universities" textFill="#5f6368" />

        <GridPane hgap="10.0" style="-fx-background-color: #E0E0E0;" vgap="5.0">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" />
                <ColumnConstraints hgrow="SOMETIMES" />
                <ColumnConstraints hgrow="SOMETIMES" />
                <ColumnConstraints hgrow="SOMETIMES" />
            </columnConstraints>
            <children>
                <Label text="University" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="uniComboBox" promptText="Select School" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                <Label text="Max Price ($/month)" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Spinner fx:id="priceSpinner" editable="true" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <valueFactory>
                        <SpinnerValueFactory.IntegerSpinnerValueFactory amountToStepBy="100" initialValue="1000" max="10000000" min="0" />
                    </valueFactory>
                </Spinner>

                <Label text="Distance (meters)" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <Spinner fx:id="distSpinner" editable="true" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <valueFactory>
                        <SpinnerValueFactory.IntegerSpinnerValueFactory amountToStepBy="100" initialValue="2000" max="20000" min="0" />
                    </valueFactory>
                </Spinner>

                <Button onAction="#handleSearch" text="🔍 Search" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            </children>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>

        </GridPane>

        <HBox spacing="10.0" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
            <children>
                <!-- Map View -->
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Map View" />
                        <WebView fx:id="webView" VBox.vgrow="ALWAYS" minHeight="-1.0" minWidth="-1.0" prefHeight="413.0" prefWidth="519.0" />
                    </children>
                </VBox>

                <!-- List View -->
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox>
                            <children>
                                <Label text="List View" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Hyperlink fx:id="distSortLink" onAction="#handleDistSort" text="= Dist Sort" />
                                <Hyperlink fx:id="sortLink" onAction="#handleSort" text="= $ Sort" />
                            </children>
                        </HBox>
                        <ListView fx:id="propertyList" prefWidth="250.0" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>

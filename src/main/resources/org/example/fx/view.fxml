<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.fx.PropertyController">
    <children>

        <VBox style="-fx-background-color: #1e3a5f; -fx-padding: 16 20 16 20;">
            <Label text="🏠 Student Property Finder"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Find rental properties near Edmonton universities."
                   style="-fx-font-size: 12px; -fx-text-fill: #a8c4e0; -fx-padding: 4 0 0 0;" />
        </VBox>

        <HBox spacing="12.0" alignment="CENTER_LEFT"
              style="-fx-background-color: #f4f6f9; -fx-padding: 12 16 12 16; -fx-border-color: #d0d7e3; -fx-border-width: 0 0 1 0;">
            <VBox spacing="3">
                <Label text="University" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                <ComboBox fx:id="uniComboBox" promptText="Select School" prefWidth="160" />
            </VBox>
            <VBox spacing="3">
                <Label text="Max Price ($/month)" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                <Spinner fx:id="priceSpinner" editable="true" prefWidth="130">
                    <valueFactory>
                        <SpinnerValueFactory.IntegerSpinnerValueFactory amountToStepBy="100" initialValue="1000" max="10000" min="200" />
                    </valueFactory>
                </Spinner>
            </VBox>
            <VBox spacing="3">
                <Label text="Distance (meters)" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                <Spinner fx:id="distSpinner" editable="true" prefWidth="130">
                    <valueFactory>
                        <SpinnerValueFactory.IntegerSpinnerValueFactory amountToStepBy="100" initialValue="2000" max="20000" min="0" />
                    </valueFactory>
                </Spinner>
            </VBox>
            <VBox spacing="3">
                <Label text=" " style="-fx-font-size: 11px;" />
                <Button onAction="#handleSearch" text="🔍  Search"
                        style="-fx-background-color: #1e3a5f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;" />
            </VBox>
        </HBox>

        <HBox spacing="10.0" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
            <children>
                <!-- Map View -->
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Map View" />
                        <WebView fx:id="webView" VBox.vgrow="ALWAYS" minHeight="-1.0" minWidth="-1.0" prefHeight="413.0" prefWidth="519.0" />
                    </children>
                </VBox>

                <!-- List View -->
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox>
                            <children>
                                <Label text="List View" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Hyperlink fx:id="distSortLink" onAction="#handleDistSort" text="= Dist Sort" />
                                <Hyperlink fx:id="sortLink" onAction="#handleSort" text="= $ Sort" />
                            </children>
                        </HBox>
                        <ListView fx:id="propertyList" prefWidth="250.0" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </HBox>

    </children>
</VBox>